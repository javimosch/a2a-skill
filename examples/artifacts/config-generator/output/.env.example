# =============================================================================
# Application (Node.js/Express)
# =============================================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database connection
DB_HOST=db
DB_PORT=5432
DB_NAME=myapp
DB_USER=myapp_user
DB_PASSWORD=change_me_in_production

# Full connection string (overrides individual DB_* vars if set)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Session / Auth
SESSION_SECRET=change_me_in_production

# CORS
CORS_ORIGIN=https://example.com

# =============================================================================
# PostgreSQL (used by the postgres:16-alpine image)
# =============================================================================
POSTGRES_USER=myapp_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=myapp

# =============================================================================
# Nginx (file-based config, no env vars needed)
# =============================================================================
# Nginx configuration is loaded from ./nginx/conf.d/default.conf
# SSL certs mounted at /etc/letsencrypt
# Static assets served from /var/www/html