# ============================================================
# Application Configuration (.env.example)
# Copy to .env and fill in your values before running compose.
# ============================================================

# ---------- Node.js / Express ----------
NODE_ENV=production
PORT=3000

# ---------- PostgreSQL Connection ----------
DB_HOST=db                     # Docker service name (internal DNS)
DB_PORT=5432
DB_NAME=myapp_production
DB_USER=myapp
DB_PASSWORD=changeme_production_secret

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                   # Internal bridge — no TLS needed

# ---------- Logging ----------
LOG_LEVEL=info                 # debug | info | warn | error
LOG_FORMAT=json                # json | text

# ---------- CORS ----------
CORS_ORIGIN=https://example.com

# ---------- Rate Limiting (App-level) ----------
RATE_LIMIT_WINDOW_MS=60000     # 1 minute window
RATE_LIMIT_MAX=100             # max requests per window

# ---------- PostgreSQL Container ----------
POSTGRES_USER=myapp            # must match DB_USER
POSTGRES_PASSWORD=changeme_production_secret  # must match DB_PASSWORD
POSTGRES_DB=myapp_production   # must match DB_NAME

# ---------- Nginx / Domain ----------
SERVER_NAME=example.com

# ---------- SSL / Certbot ----------
SSL_EMAIL=admin@example.com    # Used for Let's Encrypt notifications