# ── App ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (Postgres) ─────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=change_me_to_a_secure_password

# ── Postgres Admin ───────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change_me_to_a_secure_password

# ── Connection String ────────────────────────────────
DATABASE_URL=postgresql://appuser:change_me_to_a_secure_password@db:5432/appdb

# ── Security ─────────────────────────────────────────
SESSION_SECRET=change_me_to_a_random_64_char_secret
CORS_ORIGIN=https://example.com

# ── Observability ────────────────────────────────────
LOG_LEVEL=info