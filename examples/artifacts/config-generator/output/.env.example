# =============================================================================
# App Environment Variables
# File: ./env/app.env
# =============================================================================

# Node environment
NODE_ENV=production

# App server port (must match Dockerfile EXPOSE and nginx upstream)
PORT=3000

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# PostgreSQL Database — values must match ./env/db.env
# ---------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=change_me_in_production

# Full connection URL (derived from individual vars above)
DATABASE_URL=postgres://:@:/

# ---------------------------------------------------------------------------
# Redis (optional — uncomment when caching layer is added)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379


# =============================================================================
# Database Environment Variables
# File: ./env/db.env
# =============================================================================

# These must stay in sync with the DB_* vars above
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change_me_in_production


# =============================================================================
# Optional — Docker Compose project name override
# =============================================================================
# COMPOSE_PROJECT_NAME=myapp