# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
DB_HOST=db
DB_PORT=5432
DB_NAME=a2a_app
DB_USER=a2a_user
DB_PASSWORD=changeme
DB_SSL=false

# ─── Postgres ──────────────────────────────────────
POSTGRES_DB=a2a_app
POSTGRES_USER=a2a_user
POSTGRES_PASSWORD=changeme
PGDATA=/var/lib/postgresql/data

# ─── App Config ────────────────────────────────────
LOG_LEVEL=info
API_RATE_LIMIT=30
CORS_ORIGIN=http://localhost:3000,https://api.example.com